{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "lib": [
            "ES2022"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "baseUrl": ".",
        "types": [
            "node"
        ],
        "typeRoots": [
            "./node_modules/@types"
        ],
        "paths": {
            "@main/*": [
                "./src/main/*"
            ],
            "@preload/*": [
                "./src/preload/*"
            ],
            "@shared/*": [
                "./src/shared/*"
            ]
        }
    },
    "include": [
        "electron.vite.config.ts",
        "src/main/**/*",
        "src/preload/**/*"
    ]
}
